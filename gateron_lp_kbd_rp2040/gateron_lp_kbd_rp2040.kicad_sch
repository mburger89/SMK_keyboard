  (text "KEY MATRIX  5x12 (59 keys, COL2ROW diodes)" (exclude_from_sim no) (at 25.4 20.32 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "6e13db05-bb0b-5224-9192-02faef577f40"))
  (text "MCU -- RP2040 (VERIFY pin numbers before fab, see file header)" (exclude_from_sim no) (at 96.52 100.33 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "22a84c90-a71e-515f-8210-84fc747529b8"))
  (text "RP2040 minimum system (core SMPS, 12MHz xtal, QSPI flash)" (exclude_from_sim no) (at 96.52 63.5 0) (effects (font (size 3.0 3.0) (thickness 0.3) bold) (justify left bottom)) (uuid "64c8d66b-813b-50f0-bd1e-ac8d2786e0ab"))
  (text "Wireless (CYW43439, BLE-only) -- crystal/pinout/power topology verified against datasheet 002-30348 Rev *D; RF matching values still VERIFY (vendor/antenna-specific)" (exclude_from_sim no) (at 96.52 114.3 0) (effects (font (size 2.5 2.5) (thickness 0.3) bold) (justify left bottom)) (uuid "a0b55ead-e392-5f86-abd5-fc4f8c495fb5"))
  (text "Per-key RGB -- SK6812MINI-E x59, serpentine chain (must match Sources/smk/RGBLighting.swift ledChainIndex)" (exclude_from_sim no) (at 25.4 45.72 0) (effects (font (size 3.0 3.0) (thickness 0.3) bold) (justify left bottom)) (uuid "c10c1bc9-b82b-541c-8571-9470e19ea3e1"))
  (text "RGB chain fed from VSYS (unregulated battery/USB), NOT the 3.3V LDO -- 59 LEDs at full white can draw several amps, far beyond the AP2112K-3.3's rating. Firmware must cap brightness/concurrent-on count. Level shifter keeps DIN threshold margin safe across the VSYS voltage range." (exclude_from_sim no) (at 25.4 40.64 0) (effects (font (size 1.8 1.8) (thickness 0.3) bold) (justify left bottom)) (uuid "f377fdda-ecbe-5097-805d-2d1fc4ff1895"))
  (text "USB-C  (charge + native USB)" (exclude_from_sim no) (at 219.71 105.41 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "9f465808-eb9a-520a-b147-ab11e957ef01"))
  (text "Li-ion charger 500mA" (exclude_from_sim no) (at 287.02 105.41 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "993541a7-7716-5f7e-b437-70d769bb2732"))
  (text "Power path + 3.3V LDO + ON/OFF" (exclude_from_sim no) (at 340.36 105.41 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "82a63fae-d878-5fbc-b7da-7e156952f296"))
  (text "VBAT sense + RESET + BOOTSEL" (exclude_from_sim no) (at 391.16 105.41 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "36561a8f-71e0-596e-a5a7-745d7e0dc7df"))
  (text "GPIO map (VERIFY pin numbers, see file header):  ROW0-4 = GPIO0-4   COL0-11 = GPIO5-16   RGB_GPIO = GPIO17   VBAT_SENSE = GPIO26/ADC0   BT UART/ctrl (GPIO18-23, 28) = CYW43439 BLE link (see wireless section)" (exclude_from_sim no) (at 25.4 95.25 0) (effects (font (size 2.0 2.0) (thickness 0.3) bold) (justify left bottom)) (uuid "daccc58e-fc6a-5376-b3b2-c4c3685c7b7d"))
  (text "Charging works with power switch OFF (charger connects before switch).  BOOTSEL+RESET = USB mass-storage bootloader mode (VERIFY)." (exclude_from_sim no) (at 25.4 100.33 0) (effects (font (size 2.0 2.0) (thickness 0.3) bold) (justify left bottom)) (uuid "77438073-e4f7-5e8e-aa4e-19128581c798"))
