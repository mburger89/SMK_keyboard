  (text "KEY MATRIX  5x12 (59 keys, COL2ROW diodes)" (exclude_from_sim no) (at 25.4 20.32 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "7edbf421-3a0a-54ed-a6f7-0ef38c6fd690"))
  (text "MCU -- RP2040 (VERIFY pin numbers before fab, see file header)" (exclude_from_sim no) (at 96.52 100.33 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "75af53b6-1fae-5e10-a7fa-2710ceea77b6"))
  (text "RP2040 minimum system (core regulator, 12MHz xtal, QSPI flash)" (exclude_from_sim no) (at 96.52 63.5 0) (effects (font (size 3.0 3.0) (thickness 0.3) bold) (justify left bottom)) (uuid "d536ae05-b71f-554a-8c86-f1720bc4dd24"))
  (text "Wireless (CYW43439, BLE-only) -- crystal/pinout/power topology verified against datasheet 002-30348 Rev *D; RF matching values still VERIFY (vendor/antenna-specific)" (exclude_from_sim no) (at 96.52 114.3 0) (effects (font (size 2.5 2.5) (thickness 0.3) bold) (justify left bottom)) (uuid "1fa6eaef-f3eb-5f0f-a940-58567f9821d2"))
  (text "Per-key RGB -- SK6812MINI-E x59, serpentine chain (must match Sources/smk/RGBLighting.swift ledChainIndex)" (exclude_from_sim no) (at 25.4 45.72 0) (effects (font (size 3.0 3.0) (thickness 0.3) bold) (justify left bottom)) (uuid "82863cce-4af8-551f-8444-4feac88cd77d"))
  (text "RGB chain fed from VSYS (unregulated battery/USB), NOT the 3.3V LDO -- 59 LEDs at full white can draw several amps, far beyond the AP2112K-3.3's rating. Firmware must cap brightness/concurrent-on count. Level shifter keeps DIN threshold margin safe across the VSYS voltage range." (exclude_from_sim no) (at 25.4 40.64 0) (effects (font (size 1.8 1.8) (thickness 0.3) bold) (justify left bottom)) (uuid "0db21598-b6ee-5681-b1e6-aa259de740f2"))
  (text "USB-C  (charge + native USB)" (exclude_from_sim no) (at 219.71 105.41 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "8b455c6e-5b44-5834-82ce-ce33f7d8e77f"))
  (text "Li-ion charger 500mA" (exclude_from_sim no) (at 287.02 105.41 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "9905b211-65c4-59d6-bf67-5c0a4d7dc04f"))
  (text "Power path + 3.3V LDO + ON/OFF" (exclude_from_sim no) (at 340.36 105.41 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "50771b8c-cbd1-5f76-b167-1b3caab0612e"))
  (text "VBAT sense + RESET + BOOTSEL" (exclude_from_sim no) (at 391.16 105.41 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "1ca5d67a-e229-5e2d-b159-c79c88fc070b"))
  (text "GPIO map (VERIFY pin numbers, see file header):  ROW0-4 = GPIO0-4   COL0-11 = GPIO5-16   RGB_GPIO = GPIO17   VBAT_SENSE = GPIO26/ADC0   BT UART/ctrl (GPIO18-23, 28) = CYW43439 BLE link (see wireless section)" (exclude_from_sim no) (at 25.4 95.25 0) (effects (font (size 2.0 2.0) (thickness 0.3) bold) (justify left bottom)) (uuid "fa8d6f11-b749-5fe2-9188-bc333c8f0d58"))
  (text "Charging works with power switch OFF (charger connects before switch).  BOOTSEL+RESET = USB mass-storage bootloader mode (VERIFY)." (exclude_from_sim no) (at 25.4 100.33 0) (effects (font (size 2.0 2.0) (thickness 0.3) bold) (justify left bottom)) (uuid "5a9c599d-b94a-5f4c-8971-178fc4811dee"))
