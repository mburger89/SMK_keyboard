  (text "KEY MATRIX  5x12 (59 keys, COL2ROW diodes)" (exclude_from_sim no) (at 25.4 20.32 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "180d719c-febd-530d-b16d-88d9c0d14496"))
  (text "MCU -- RP2040 (VERIFY pin numbers before fab, see file header)" (exclude_from_sim no) (at 96.52 100.33 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "b6c3fb56-1b31-5491-99bc-a35e4eb3b058"))
  (text "RP2040 minimum system (core regulator, 12MHz xtal, QSPI flash)" (exclude_from_sim no) (at 96.52 63.5 0) (effects (font (size 3.0 3.0) (thickness 0.3) bold) (justify left bottom)) (uuid "b50aa462-3a77-581d-8efc-024f39bf1660"))
  (text "Wireless (CYW43439, BLE-only) -- crystal/pinout/power topology verified against datasheet 002-30348 Rev *D; RF matching values still VERIFY (vendor/antenna-specific)" (exclude_from_sim no) (at 96.52 114.3 0) (effects (font (size 2.5 2.5) (thickness 0.3) bold) (justify left bottom)) (uuid "c6eab6be-bc30-5fa3-970f-7a4d265f4396"))
  (text "Per-key RGB -- SK6812MINI-E x59, serpentine chain (must match Sources/smk/RGBLighting.swift ledChainIndex)" (exclude_from_sim no) (at 25.4 45.72 0) (effects (font (size 3.0 3.0) (thickness 0.3) bold) (justify left bottom)) (uuid "ca676472-9b9a-5524-b3fa-46ffbd01c387"))
  (text "RGB chain fed from VSYS (unregulated battery/USB), NOT the 3.3V LDO -- 59 LEDs at full white can draw several amps, far beyond the AP2112K-3.3's rating. Firmware must cap brightness/concurrent-on count. Level shifter keeps DIN threshold margin safe across the VSYS voltage range." (exclude_from_sim no) (at 25.4 40.64 0) (effects (font (size 1.8 1.8) (thickness 0.3) bold) (justify left bottom)) (uuid "e571fbf8-f295-5c25-b847-a4a35e6e5fed"))
  (text "USB-C  (charge + native USB)" (exclude_from_sim no) (at 219.71 105.41 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "21683852-fffb-5bbf-81da-da0a470e0a86"))
  (text "Li-ion charger 500mA" (exclude_from_sim no) (at 287.02 105.41 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "a6b5b2d7-1788-5a7f-93f0-d0c04a3505de"))
  (text "Power path + 3.3V LDO + ON/OFF" (exclude_from_sim no) (at 340.36 105.41 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "fe834721-321d-5b73-9357-5bd025820fdc"))
  (text "VBAT sense + RESET + BOOTSEL" (exclude_from_sim no) (at 391.16 105.41 0) (effects (font (size 3.81 3.81) (thickness 0.3) bold) (justify left bottom)) (uuid "392f02c3-2d8e-561c-b22a-425645f3cd9e"))
  (text "GPIO map (VERIFY pin numbers, see file header):  ROW0-4 = GPIO0-4   COL0-11 = GPIO5-16   RGB_GPIO = GPIO17   VBAT_SENSE = GPIO26/ADC0   BT UART/ctrl (GPIO18-23, 28) = CYW43439 BLE link (see wireless section)" (exclude_from_sim no) (at 25.4 95.25 0) (effects (font (size 2.0 2.0) (thickness 0.3) bold) (justify left bottom)) (uuid "4a32ed8e-e0ae-504e-a378-0e174d5b5bbe"))
  (text "Charging works with power switch OFF (charger connects before switch).  BOOTSEL+RESET = USB mass-storage bootloader mode (VERIFY)." (exclude_from_sim no) (at 25.4 100.33 0) (effects (font (size 2.0 2.0) (thickness 0.3) bold) (justify left bottom)) (uuid "56621e1e-f1ea-57f4-8ed2-ce3f9a0cccdc"))
