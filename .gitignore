__pycache__/
.DS_Store
*.lck
*.zip

# kicad-happy analyzer output -- regenerable, timestamped per run
analysis/

# KiCad's own per-file version-history folders (embedded git repos)
.history/

# stray/unidentified files found in this directory before git init
zi3NjsFM
*kleplace*

# local venv for route_kbd.py's dependencies (sexpdata, numpy, shapely)
.routing_venv/

# route_kbd_rp2040.py's own intermediate output -- regenerated by running
# the script; generate_kbd_rp2040.py reads it back in on the next run, but
# it isn't itself source (the committed .kicad_pcb is the artifact meant
# to be opened/shared).
gateron_lp_kbd_rp2040/tracks_rp2040.sexp

# KiCad 3D viewer / exporter session artifacts (glTF/VRML export, unsaved
# project-local-settings snapshots) -- large, fully regenerable from the
# .kicad_pcb, not meant to be committed.
*.glb
*.wrl
**/shapes3D/
*-unsaved-export-*.kicad_prl
